# Database
DATABASE_URL=postgresql://hub:hub@localhost:5432/realtime_hub

# Redis (used by both pub/sub and Celery broker/backend)
REDIS_URL=redis://localhost:6379/0

# Flask
SECRET_KEY=change-me-to-a-random-32-char-string

# AWS (required for deploy.sh)
AWS_REGION=us-east-1
ECR_REGISTRY=<account-id>.dkr.ecr.us-east-1.amazonaws.com
ECR_REPOSITORY=realtime-hub
ECS_CLUSTER=realtime-hub-cluster
ECS_SERVICE=realtime-hub-service
SUBNET_IDS=subnet-xxxxxxxx,subnet-yyyyyyyy
SECURITY_GROUP_IDS=sg-xxxxxxxx
